# ─────────────────────────────────────────────
# Spotify API — REMOVED
# Dropped: Spotify requires Premium for Web API
# as of February 2026 policy change.
# ─────────────────────────────────────────────
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=

# ─────────────────────────────────────────────
# YouTube Music
# Setup: run `ytmusicapi browser` in terminal
# ─────────────────────────────────────────────
YTMUSIC_AUTH_FILE=ytmusic_auth.json

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_USER=vibeflow
POSTGRES_PASSWORD=vibeflow_secret
POSTGRES_DB=vibeflow_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─────────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────
# App Config
# ─────────────────────────────────────────────
LOCAL_MUSIC_DIR=./music_library
PLAYLIST_DIR=./music_library/playlists
DAILY_REC_TIME=08:00
WEEKEND_PLAYLIST_TIME=19:00
APP_ENV=development
LOG_LEVEL=INFO
